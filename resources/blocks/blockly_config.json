{
  "grid": {
    "spacing": 20,
    "length": 3,
    "colour": "#ccc",
    "snap": false
  },
  "zoom": {
    "controls": true,
    "wheel": true,
    "startScale": 1.0,
    "maxScale": 3,
    "minScale": 0.3,
    "scaleSpeed": 1.2
  },
  "move": {
    "scrollbars": {
      "horizontal": true,
      "vertical": true
    },
    "drag": true,
    "wheel": false
  },
  "theme": "classic",
  "renderer": "geras"
}